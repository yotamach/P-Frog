{
  "name": "p-frog-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/p-frog-e2e/src",
  "projectType": "application",
  "tags": [],
  "implicitDependencies": ["p-frog"],
  "targets": {
    "e2e": {
      "executor": "@nx/cypress:cypress",
      "options": {
        "cypressConfig": "apps/p-frog-e2e/cypress.config.ts",
        "baseUrl": "http://localhost:4200"
      },
      "configurations": {
        "production": {
          "baseUrl": "http://localhost:4200"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/p-frog-e2e/**/*.{js,ts}"]
      }
    }
  }
}
