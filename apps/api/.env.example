# Backend API Environment Variables
# Copy this file to .env.development, .env.production, and .env.test and fill in the values

# Server Configuration
SERVER_HOST=localhost
SERVER_PORT=3333

# Database Configuration
DB_HOST=localhost
DB_PORT=27017
DB_SCHEMA=p-frog
DB_USERNAME=<your-db-username>
DB_PASSWORD=<your-db-password>

# better-auth configuration
# Secret for signing sessions (use a long random string, min 32 chars)
BETTER_AUTH_SECRET=<your-better-auth-secret>
# Public URL of this API server (used by better-auth for redirects)
BETTER_AUTH_URL=http://localhost:3333
# Frontend origin (for CORS credentials)
FRONTEND_URL=http://localhost:4200

# Email (SMTP) configuration for Magic Link auth
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=<your-smtp-user>
SMTP_PASS=<your-smtp-password>
SMTP_FROM=noreply@p-frog.com

# Legacy (no longer used — kept for reference)
# JWT_SECRET=<your-jwt-secret>
# SESSION_SECRET=<your-session-secret>
