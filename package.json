  "scripts": {
    "start": "nx serve p-frog",
    "start:server-dev": "nx serve api",
    "start:server-prod": "nx serve api --configuration=production",
    "build": "nx build p-frog",
    "build:dev": "nx build p-frog --configuration=development",
    "build:server": "nx build api --configuration=production",
    "build:server-dev": "nx build api --configuration=development",
    "build:all": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint --fix",
    "client:test": "nx test",
    "test:server": "nx test api",
    "e2e": "nx e2e p-frog-e2e",
    "e2e:watch": "nx e2e p-frog-e2e --watch",
    "e2e:headless": "nx e2e p-frog-e2e --headless",
    "preview": "vite preview --config apps/p-frog/vite.config.ts",
    "postinstall": "bash tools/install-hooks.sh"
  },
