#!/bin/bash

# Commit message hook to validate format: PF-{number} {message}

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Skip validation for merge commits
if grep -q "^Merge" "$COMMIT_MSG_FILE"; then
    exit 0
fi

# Validate commit message pattern: PF-{number} {message}
if [[ ! "$COMMIT_MSG" =~ ^PF-[0-9]+[[:space:]].+ ]]; then
    echo ""
    echo "❌ ERROR: Commit message does not match the required pattern"
    echo ""
    echo "Commit message format: PF-{number} {message}"
    echo ""
    echo "Valid examples:"
    echo "  ✓ PF-123 Add user authentication"
    echo "  ✓ PF-456 Fix navigation bug"
    echo "  ✓ PF-789 Update API documentation"
    echo ""
    echo "Invalid examples:"
    echo "  ✗ Add user authentication (missing PF-{number})"
    echo "  ✗ PF-123: Add feature (colon not allowed after number)"
    echo "  ✗ PF-123 (missing message)"
    echo ""
    echo "Your commit message:"
    echo "  $COMMIT_MSG"
    echo ""
    exit 1
fi

echo "✅ Commit message is valid"
exit 0
