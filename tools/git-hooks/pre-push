#!/bin/bash

# Pre-push hook to validate branch name pattern: PF-{number}_{Letters}

# Get the current branch name
BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)

# Skip validation for master branch
if [ "$BRANCH_NAME" = "master" ]; then
    exit 0
fi

# Validate branch name pattern: PF-{number}_{Letters}
if [[ ! "$BRANCH_NAME" =~ ^PF-[0-9]+_[A-Za-z]+$ ]]; then
    echo ""
    echo "❌ ERROR: Branch name '$BRANCH_NAME' does not match the required pattern"
    echo ""
    echo "Branch naming convention: PF-{number}_{LettersOnly}"
    echo ""
    echo "Valid examples:"
    echo "  ✓ PF-123_FeatureName"
    echo "  ✓ PF-456_BugFix"
    echo "  ✓ PF-789_Update"
    echo ""
    echo "Invalid examples:"
    echo "  ✗ feature/new-thing"
    echo "  ✗ PF-123"
    echo "  ✗ PF-123_bug-fix (hyphens not allowed)"
    echo "  ✗ PF-123_Feature_123 (numbers not allowed after underscore)"
    echo ""
    exit 1
fi

echo "✅ Branch name '$BRANCH_NAME' is valid"
exit 0
